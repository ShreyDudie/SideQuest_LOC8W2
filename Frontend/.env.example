# ==============================================================
# SideQuest Frontend Environment Variables
# Copy this file to .env.local and fill in the values
# ==============================================================

# Groq API Key for AI features (PPT evaluation, repo chatbot, helpline AI)
# Get your key from https://console.groq.com → API Keys
VITE_GROQ_API_KEY=

# Backend API URL (Django)
VITE_API_URL=http://localhost:8000
